# Configuration Supabase pour Syndory
# Copier ce fichier en .env et remplir les valeurs

# Supabase Project
SUPABASE_URL=https://votre-project-ref.supabase.co
SUPABASE_ANON_KEY=votre-cle-anon
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role

# Configuration locale (développement)
SUPABASE_LOCAL_URL=http://localhost:54321
SUPABASE_LOCAL_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Storage
STORAGE_AVATARS_BUCKET=avatars
STORAGE_RESOURCES_BUCKET=resources
STORAGE_JUSTIFICATIFS_BUCKET=justificatifs
STORAGE_ANNONCES_BUCKET=annonces

# Edge Functions
FUNCTIONS_URL=https://votre-project-ref.supabase.co/functions/v1

# Push Notifications (Firebase)
FCM_SERVER_KEY=votre-cle-fcm

# Email (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App Configuration
DEFAULT_GPS_TOLERANCE=50
ATTENDANCE_CRITICAL_THRESHOLD=70
DEFAULT_MARKING_WINDOW=15
